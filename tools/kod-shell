#!/bin/bash

mkdir -p ~/.config/overlay
mkdir -p ~/.config/overlay/{upper,work,rootfs}

sudo mount -t overlay overlay -o lowerdir=/,upperdir=/home/abuss/.config/overlay/upper,workdir=/home/abuss/.config/overlay/work /home/abuss/.config/overlay/rootfs

if [ "$1" == "-p" ]; then 
    # sudo mount --bind /root /home/abuss/.config/overlay/rootfs/root
    # sudo mount --bind /home /home/abuss/.config/overlay/rootfs/home
    sudo mount --bind /var/cache /home/abuss/.config/overlay/rootfs/var/cache
    sudo mount --bind /var/tmp /home/abuss/.config/overlay/rootfs/var/tmp
    sudo mount --bind /var/log /home/abuss/.config/overlay/rootfs/var/log
    # sudo mount --bind /kod /home/abuss/.config/overlay/rootfs/kod

    sudo arch-chroot /home/abuss/.config/overlay/rootfs pacman -S --noconfirm $2

    sudo umount -R /home/abuss/.config/overlay/rootfs
fi

proot -r /home/abuss/.config/overlay/rootfs -b /proc -b /sys -b /dev -b /home -b /var/cache -b /var/tmp -b /var/log /bin/bash

sudo umount -R /home/abuss/.config/overlay/rootfs

sudo rm -rf /home/abuss/.config/overlay
